# Sheets logging uses a service account (works fine, no human login needed).
# GOOGLE_SERVICE_ACCOUNT_JSON is the full downloaded service-account JSON,
# minified to one line. The service account's email must be shared as an
# editor on the target Sheet.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_ID=
GOOGLE_DRIVE_FOLDER_ID=

# Drive uploads use OAuth with a real Google account instead: a service
# account has no storage quota of its own, so its uploads into a personal
# "My Drive" folder are rejected even with editor access. These three make
# uploads count against the real account's own 15GB.
# GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET come from a Google
# Cloud "OAuth client ID" (Web application). GOOGLE_OAUTH_REFRESH_TOKEN is
# produced once by visiting /api/google/oauth/start in a browser and
# approving access; copy it from the confirmation page it shows you.
# Keep real values out of git.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
